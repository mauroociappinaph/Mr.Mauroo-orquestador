# Browser/client gateway URL (build-time — requires `npm run build` after changes)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Runtime gateway URL — takes effect on restart without a rebuild.
# Use this to change the gateway endpoint without re-running `npm run build`.
# GATEWAY_URL=ws://localhost:18789
# GATEWAY_TOKEN=
# GATEWAY_ADAPTER_TYPE=custom

# Debug UI
DEBUG=true

# App server
# PORT=3000
# HOST=127.0.0.1

# Optional: required only for public/remote deployments
# STUDIO_ACCESS_TOKEN=

# Demo gateway
# Run `npm run demo-gateway` and connect the app to ws://localhost:18789
# DEMO_ADAPTER_PORT=18789

# Optional: voice features
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
